#!/usr/bin/env bash
# Unified GenericAgent service manager.
# Manage only GenericAgent services in this repository; it intentionally does
# not touch external services such as Hermes.

set -u

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_PATH" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
  LINK_TARGET="$(readlink "$SCRIPT_PATH")"
  case "$LINK_TARGET" in
    /*) SCRIPT_PATH="$LINK_TARGET" ;;
    *) SCRIPT_PATH="$SCRIPT_DIR/$LINK_TARGET" ;;
  esac
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" >/dev/null 2>&1 && pwd)"
SCRIPT_PATH="$SCRIPT_DIR/$(basename "$SCRIPT_PATH")"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"

RUN_DIR="$REPO_ROOT/temp/run"
DEFAULT_SERVICE="wechat"

usage() {
  cat <<USAGE
Usage:
  ga-service [service] <command> [args]
  ga-service <command> [args]              # defaults to service: $DEFAULT_SERVICE

Services:
  wechat        GA WeChat customer-service frontend (frontends/wechatapp.py)

Commands:
  list                                  Show manageable services
  start [service]                       Start service in background
  stop [service]                        Stop service using verified PID/process match
  restart [service]                     Restart service
  status [service|all]                  Show service status
  logs [service] [--runner|--app] [-n N] Show recent logs
  qr [service]                          Show WeChat QR path/status and render in terminal if available
  install-bin [--user|--system] [name]       Install a symlink for direct execution
  uninstall-bin [--user|--system] [name]     Remove that symlink if it points to this script
  help                                  Show this help

Examples:
  /home/ubuntu/tool/GenericAgent/ops/ga-service wechat start
  /home/ubuntu/tool/GenericAgent/ops/ga-service status
  ga-service wechat restart             # after install-bin
  ga-service logs -n 100
  ga-service qr
USAGE
}

log() { printf '[ga-service] %s\n' "$*"; }
err() { printf '[ga-service][ERROR] %s\n' "$*" >&2; }

ensure_dirs() {
  mkdir -p "$REPO_ROOT/temp" "$RUN_DIR"
}

service_label() {
  case "$1" in
    wechat) printf '%s\n' 'GA WeChat frontend' ;;
    *) return 1 ;;
  esac
}

service_script_abs() {
  case "$1" in
    wechat) printf '%s\n' "$REPO_ROOT/frontends/wechatapp.py" ;;
    *) return 1 ;;
  esac
}

service_workdir() {
  case "$1" in
    wechat) printf '%s\n' "$REPO_ROOT" ;;
    *) return 1 ;;
  esac
}

service_python() {
  case "$1" in
    wechat) printf '%s\n' "$REPO_ROOT/.venv/bin/python" ;;
    *) return 1 ;;
  esac
}

service_runner_log() {
  case "$1" in
    wechat) printf '%s\n' "$REPO_ROOT/temp/wechatapp.runner.log" ;;
    *) return 1 ;;
  esac
}

service_app_log() {
  case "$1" in
    wechat) printf '%s\n' "$REPO_ROOT/temp/wechatapp.log" ;;
    *) return 1 ;;
  esac
}

service_pidfile() {
  case "$1" in
    wechat) printf '%s\n' "$RUN_DIR/wechat.pid" ;;
    *) return 1 ;;
  esac
}

service_rel_script() {
  case "$1" in
    wechat) printf '%s\n' 'frontends/wechatapp.py' ;;
    *) return 1 ;;
  esac
}

require_service() {
  case "${1:-}" in
    wechat) return 0 ;;
    ''|help|-h|--help) return 1 ;;
    *) err "Unknown service: $1"; return 1 ;;
  esac
}

ps_cmd_for_pid() {
  ps -p "$1" -o args= 2>/dev/null || true
}

pid_matches_service() {
  svc="$1"
  pid="$2"
  [ -n "${pid:-}" ] || return 1
  case "$pid" in *[!0-9]*|'') return 1 ;; esac
  cmd="$(ps_cmd_for_pid "$pid")"
  [ -n "$cmd" ] || return 1
  script_abs="$(service_script_abs "$svc")"
  script_rel="$(service_rel_script "$svc")"
  case "$cmd" in
    *"$script_abs"*|*"$script_rel"*) return 0 ;;
    *) return 1 ;;
  esac
}

find_service_pids() {
  svc="$1"
  script_abs="$(service_script_abs "$svc")"
  script_rel="$(service_rel_script "$svc")"
  ps -eo pid=,args= | awk -v abs="$script_abs" -v rel="$script_rel" '
    index($0, abs) || index($0, rel) {print $1}
  '
}

service_pid() {
  svc="$1"
  pidfile="$(service_pidfile "$svc")"
  if [ -f "$pidfile" ]; then
    pid="$(sed -n '1p' "$pidfile" 2>/dev/null | tr -cd '0-9')"
    if pid_matches_service "$svc" "$pid"; then
      printf '%s\n' "$pid"
      return 0
    fi
  fi
  find_service_pids "$svc" | head -n 1
}

is_running() {
  svc="$1"
  pid="$(service_pid "$svc")"
  [ -n "$pid" ] && pid_matches_service "$svc" "$pid"
}

check_prereq() {
  svc="$1"
  py="$(service_python "$svc")"
  script="$(service_script_abs "$svc")"
  if [ ! -x "$py" ]; then
    err "Python executable not found/executable: $py"
    err "Run from repo setup first, or create the .venv."
    return 1
  fi
  if [ ! -f "$script" ]; then
    err "Service entry not found: $script"
    return 1
  fi
  return 0
}

start_service() {
  svc="$1"
  require_service "$svc" || return 2
  ensure_dirs
  check_prereq "$svc" || return 1
  if is_running "$svc"; then
    pid="$(service_pid "$svc")"
    log "$(service_label "$svc") already running (pid=$pid)"
    return 0
  fi
  workdir="$(service_workdir "$svc")"
  py="$(service_python "$svc")"
  script_rel="$(service_rel_script "$svc")"
  runner_log="$(service_runner_log "$svc")"
  pidfile="$(service_pidfile "$svc")"
  log "Starting $(service_label "$svc")..."
  (
    cd "$workdir"
    nohup "$py" "$script_rel" >> "$runner_log" 2>&1 &
    printf '%s\n' "$!" > "$pidfile"
  )
  sleep 1
  pid="$(service_pid "$svc")"
  if [ -n "$pid" ] && pid_matches_service "$svc" "$pid"; then
    log "Started $(service_label "$svc") (pid=$pid)"
    status_service "$svc"
    return 0
  fi
  err "Start command returned but service is not running. Runner log: $runner_log"
  tail -80 "$runner_log" 2>/dev/null || true
  return 1
}

stop_service() {
  svc="$1"
  require_service "$svc" || return 2
  pid="$(service_pid "$svc")"
  pidfile="$(service_pidfile "$svc")"
  if [ -z "$pid" ] || ! pid_matches_service "$svc" "$pid"; then
    log "$(service_label "$svc") is not running"
    [ -f "$pidfile" ] && rm -f "$pidfile"
    return 0
  fi
  log "Stopping $(service_label "$svc") (pid=$pid)..."
  kill "$pid" 2>/dev/null || true
  for _ in $(seq 1 20); do
    if ! pid_matches_service "$svc" "$pid"; then
      rm -f "$pidfile"
      log "Stopped $(service_label "$svc")"
      return 0
    fi
    sleep 0.5
  done
  err "Process still running after graceful stop; sending TERM again (pid=$pid)"
  kill -TERM "$pid" 2>/dev/null || true
  sleep 1
  if pid_matches_service "$svc" "$pid"; then
    err "Failed to stop pid=$pid. Inspect manually before using kill -9."
    return 1
  fi
  rm -f "$pidfile"
  log "Stopped $(service_label "$svc")"
}

restart_service() {
  svc="$1"
  stop_service "$svc" || return $?
  start_service "$svc"
}

status_service() {
  svc="$1"
  require_service "$svc" || return 2
  ensure_dirs
  pid="$(service_pid "$svc")"
  runner_log="$(service_runner_log "$svc")"
  app_log="$(service_app_log "$svc")"
  printf 'service=%s label="%s"\n' "$svc" "$(service_label "$svc")"
  if [ -n "$pid" ] && pid_matches_service "$svc" "$pid"; then
    printf 'status=running pid=%s\n' "$pid"
    ps -p "$pid" -o pid=,ppid=,stat=,pcpu=,pmem=,etime=,args= 2>/dev/null || true
  else
    printf 'status=stopped\n'
  fi
  printf 'repo_root=%s\n' "$REPO_ROOT"
  printf 'runner_log=%s\n' "$runner_log"
  printf 'app_log=%s\n' "$app_log"
  if [ "$svc" = "wechat" ]; then
    qr="$HOME/.wxbot/wx_qr.png"
    token="$HOME/.wxbot/token.json"
    printf 'wechat_qr=%s exists=%s\n' "$qr" "$([ -f "$qr" ] && echo yes || echo no)"
    # metadata only; never print token content
    if [ -f "$token" ]; then
      printf 'wechat_token=%s exists=yes size=%s\n' "$token" "$(wc -c < "$token" | tr -d ' ')"
    else
      printf 'wechat_token=%s exists=no\n' "$token"
    fi
  fi
}

logs_service() {
  svc="$1"; shift || true
  require_service "$svc" || return 2
  mode="both"
  n="80"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --runner) mode="runner"; shift ;;
      --app) mode="app"; shift ;;
      -n|--lines) shift; n="${1:-80}"; shift || true ;;
      --follow|-f) err "Follow mode is intentionally not enabled in this manager; use tail -f on the printed log path."; return 2 ;;
      *) err "Unknown logs option: $1"; return 2 ;;
    esac
  done
  case "$n" in *[!0-9]*|'') n=80 ;; esac
  runner_log="$(service_runner_log "$svc")"
  app_log="$(service_app_log "$svc")"
  if [ "$mode" = "both" ] || [ "$mode" = "runner" ]; then
    printf -- '--- runner log: %s ---\n' "$runner_log"
    tail -n "$n" "$runner_log" 2>/dev/null || true
  fi
  if [ "$mode" = "both" ] || [ "$mode" = "app" ]; then
    printf -- '--- app log: %s ---\n' "$app_log"
    tail -n "$n" "$app_log" 2>/dev/null || true
  fi
}

qr_service() {
  svc="$1"
  require_service "$svc" || return 2
  if [ "$svc" != "wechat" ]; then
    err "QR is only defined for service: wechat"
    return 2
  fi
  qr="$HOME/.wxbot/wx_qr.png"
  token="$HOME/.wxbot/token.json"
  printf 'qr_path=%s exists=%s\n' "$qr" "$([ -f "$qr" ] && echo yes || echo no)"
  if [ -f "$token" ]; then
    printf 'token_exists=yes token_path=%s  # metadata only; content is not printed\n' "$token"
  else
    printf 'token_exists=no token_path=%s\n' "$token"
  fi
  if [ ! -f "$qr" ]; then
    err "QR file not found. Start the service first: $0 wechat start"
    return 1
  fi
  py="$REPO_ROOT/.venv/bin/python"
  if [ ! -x "$py" ]; then py="python3"; fi
  "$py" - "$qr" <<'PY' || {
import sys
from pathlib import Path
try:
    from PIL import Image
except Exception as e:
    print(f"Cannot render QR without Pillow/PIL: {e}")
    raise SystemExit(0)
p=Path(sys.argv[1])
im=Image.open(p).convert('L')
# Downscale to terminal-friendly blocks; preserve square-ish image.
max_w=70
w,h=im.size
scale=max(1, (w + max_w - 1)//max_w)
w2=max(1, w//scale)
h2=max(1, h//scale)
im=im.resize((w2,h2))
for y in range(0,h2,2):
    line=[]
    for x in range(w2):
        top=im.getpixel((x,y))<160
        bot=im.getpixel((x,y+1))<160 if y+1<h2 else False
        if top and bot: ch='█'
        elif top: ch='▀'
        elif bot: ch='▄'
        else: ch=' '
        line.append(ch)
    print(''.join(line).rstrip())
PY
    true
  }
}

list_services() {
  printf 'wechat\t%s\n' "$(service_label wechat)"
}

install_bin() {
  scope="user"
  case "${1:-}" in
    --user) scope="user"; shift ;;
    --system) scope="system"; shift ;;
  esac
  name="${1:-ga-service}"
  case "$name" in */*|'') err "Invalid command name: $name"; return 2 ;; esac
  case "$scope" in
    user) target_dir="$HOME/.local/bin" ;;
    system) target_dir="/usr/local/bin" ;;
    *) err "Invalid install scope: $scope"; return 2 ;;
  esac
  target="$target_dir/$name"

  if [ -e "$target" ] || [ -L "$target" ]; then
    existing_link="$(readlink "$target" 2>/dev/null || true)"
    existing_abs="$(readlink -f "$target" 2>/dev/null || true)"
    if [ -L "$target" ] && { [ "$existing_link" = "$SCRIPT_PATH" ] || [ "$existing_abs" = "$SCRIPT_PATH" ]; }; then
      if [ "$existing_link" = "$SCRIPT_PATH" ]; then
        log "Already installed: $target -> $SCRIPT_PATH"
      else
        rm_cmd="rm -f '$target' && ln -s '$SCRIPT_PATH' '$target'"
        if [ -w "$(dirname "$target")" ]; then
          rm -f "$target" && ln -s "$SCRIPT_PATH" "$target" || return $?
        elif command -v sudo >/dev/null 2>&1; then
          sudo sh -c "$rm_cmd" || return $?
        else
          err "No write permission for $(dirname "$target") and sudo is unavailable."
          return 1
        fi
        log "Repaired symlink: $target -> $SCRIPT_PATH"
      fi
    elif [ -L "$target" ] && [ "$existing_link" = "ops/ga-service" ]; then
      rm_cmd="rm -f '$target' && ln -s '$SCRIPT_PATH' '$target'"
      if [ -w "$(dirname "$target")" ]; then
        rm -f "$target" && ln -s "$SCRIPT_PATH" "$target" || return $?
      elif command -v sudo >/dev/null 2>&1; then
        sudo sh -c "$rm_cmd" || return $?
      else
        err "No write permission for $(dirname "$target") and sudo is unavailable."
        return 1
      fi
      log "Repaired legacy relative symlink: $target -> $SCRIPT_PATH"
    else
      err "$target already exists and does not point to this script; leaving untouched."
      return 1
    fi
  else
    mkdir_cmd="mkdir -p '$target_dir'"
    ln_cmd="ln -s '$SCRIPT_PATH' '$target'"
    if [ -w "$(dirname "$target_dir")" ] || [ -w "$target_dir" ] 2>/dev/null; then
      mkdir -p "$target_dir" && ln -s "$SCRIPT_PATH" "$target" || return $?
    elif command -v sudo >/dev/null 2>&1; then
      sudo sh -c "$mkdir_cmd && $ln_cmd" || return $?
    else
      err "No write permission for $target_dir and sudo is unavailable."
      return 1
    fi
    log "Installed symlink: $target -> $SCRIPT_PATH"
  fi

  case ":$PATH:" in
    *":$target_dir:"*) ;;
    *) log "Note: $target_dir is not in PATH for this shell. Use --system or add it to PATH if direct command is not found." ;;
  esac
}

uninstall_bin() {
  scope="user"
  case "${1:-}" in
    --user) scope="user"; shift ;;
    --system) scope="system"; shift ;;
  esac
  name="${1:-ga-service}"
  case "$name" in */*|'') err "Invalid command name: $name"; return 2 ;; esac
  case "$scope" in
    user) target="$HOME/.local/bin/$name" ;;
    system) target="/usr/local/bin/$name" ;;
    *) err "Invalid uninstall scope: $scope"; return 2 ;;
  esac

  if [ -L "$target" ] && [ "$(readlink "$target")" = "$SCRIPT_PATH" ]; then
    if [ -w "$(dirname "$target")" ]; then
      rm -f "$target" || return $?
    elif command -v sudo >/dev/null 2>&1; then
      sudo rm -f "$target" || return $?
    else
      err "No write permission for $(dirname "$target") and sudo is unavailable."
      return 1
    fi
    log "Removed symlink: $target"
  elif [ -e "$target" ] || [ -L "$target" ]; then
    err "$target exists but does not point to this script; leaving untouched."
    return 1
  else
    log "$target is not installed"
  fi
}

# Argument normalization: allow both `ga-service wechat start` and `ga-service start wechat`.
main() {
  if [ "$#" -eq 0 ]; then usage; return 0; fi
  first="$1"
  case "$first" in
    help|-h|--help) usage; return 0 ;;
    list) list_services; return 0 ;;
    install-bin) shift; install_bin "$@"; return $? ;;
    uninstall-bin) shift; uninstall_bin "$@"; return $? ;;
  esac

  if require_service "$first" >/dev/null 2>&1; then
    svc="$first"; shift
    cmd="${1:-status}"; [ "$#" -gt 0 ] && shift || true
  else
    cmd="$first"; shift
    case "$cmd" in
      status)
        if [ "${1:-}" = "all" ]; then
          svc="all"
          shift
        else
          svc="${1:-$DEFAULT_SERVICE}"
          if require_service "$svc" >/dev/null 2>&1; then shift || true; else svc="$DEFAULT_SERVICE"; fi
        fi
        ;;
      start|stop|restart|logs|qr)
        svc="${1:-$DEFAULT_SERVICE}"
        if require_service "$svc" >/dev/null 2>&1; then shift || true; else svc="$DEFAULT_SERVICE"; fi
        ;;
      *) err "Unknown service or command: $cmd"; usage; return 2 ;;
    esac
  fi

  case "$cmd" in
    start) start_service "$svc" ;;
    stop) stop_service "$svc" ;;
    restart) restart_service "$svc" ;;
    status)
      if [ "$svc" = "all" ]; then status_service wechat; else status_service "$svc"; fi
      ;;
    logs) logs_service "$svc" "$@" ;;
    qr) qr_service "$svc" ;;
    help|-h|--help) usage ;;
    *) err "Unknown command: $cmd"; usage; return 2 ;;
  esac
}

main "$@"
