{
  "productName": "GenericAgent",
  "version": "0.1.0",
  "identifier": "com.genericagent.app",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
